# Frontend Environment Variables

# Use the default proxy in Vite so frontend API calls go to the backend automatically.
# The app uses relative paths like /api/auth/login, which works when the frontend
# is served from the same machine on localhost.

# If you need to override the backend target, uncomment and set the port below.
# VITE_API_PROXY_TARGET=http://localhost:5000
# VITE_API_PORT=5000

# Production backend base URL for frontend when deployed to Vercel.
# Set this in your Vercel frontend project environment variables.
# VITE_API_URL=https://attendance-pro.vercel.app/api
